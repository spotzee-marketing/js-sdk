{
  "name": "@spotzee/js-sdk",
  "version": "0.4.2",
  "description": "Spotzee JavaScript SDK for collecting events",
  "scripts": {
    "generate": "openapi-ts",
    "package:build": "rimraf lib/ && npm run generate && npm run package:build:esm && npm run package:build:cjs && node scripts/write-dist-package-json.mjs",
    "package:build:esm": "tsc --project ./tsconfig.module.json",
    "package:build:cjs": "tsc --project ./tsconfig.json",
    "package:publish": "npm run package:build && npm version $npm_config_tag --no-git-tag-version && npm pack && npm publish --tag=latest --access public"
  },
  "types": "./lib/cjs/index.d.ts",
  "main": "./lib/cjs/index.js",
  "module": "./lib/esm/index.js",
  "exports": {
    ".": {
      "types": "./lib/cjs/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    },
    "./generated": {
      "types": "./lib/cjs/src/generated-public.d.ts",
      "import": "./lib/esm/src/generated-public.js",
      "require": "./lib/cjs/src/generated-public.js"
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "keywords": [
    "spotzee",
    "js"
  ],
  "author": "Roshan Jonnalagadda",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spotzee-marketing/js-sdk.git"
  },
  "homepage": "https://github.com/spotzee-marketing/js-sdk#readme",
  "bugs": {
    "url": "https://github.com/spotzee-marketing/js-sdk/issues"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "^0.97.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.2"
  },
  "files": [
    "lib",
    "index.ts"
  ]
}
